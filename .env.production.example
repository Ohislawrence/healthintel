# ────────────────────────────────────────────────
# HealthIntel Production Environment
# ────────────────────────────────────────────────
# Copy to .env on your production server and fill in values

APP_NAME=HealthIntel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://healthintel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── Database ────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=healthintel
DB_USERNAME=root
DB_PASSWORD=

# ── Session ─────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=3600
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache & Queue ───────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ───────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=mail.privateemail.com
MAIL_PORT=587
MAIL_USERNAME=hello@healthintel.app
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@healthintel.app
MAIL_FROM_NAME=HealthIntel

# ── APIs ───────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_
PAYSTACK_PUBLIC_KEY=pk_live_
PAYSTACK_BASE_URL=https://api.paystack.co

DEEPSEEK_API_KEY=sk-
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.3

# ── Security ───────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=*

# Sanctum token expiration (43200 = 30 days)
SANCTUM_TOKEN_EXPIRATION=43200
SANCTUM_STATEFUL_DOMAINS=healthintel.app,www.healthintel.app